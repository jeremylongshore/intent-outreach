{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://pipelinepilot.io/schemas/news_story.json",
  "title": "NewsStory",
  "description": "Schema for news article with scoring and selection rationale",
  "type": "object",
  "properties": {
    "id": {
      "type": "string",
      "description": "Unique story identifier"
    },
    "title": {
      "type": "string",
      "minLength": 10,
      "maxLength": 200,
      "description": "Article headline"
    },
    "summary": {
      "type": "string",
      "minLength": 40,
      "maxLength": 300,
      "description": "Brief article summary"
    },
    "body": {
      "type": "string",
      "minLength": 400,
      "maxLength": 4000,
      "description": "Full article content"
    },
    "source": {
      "type": "object",
      "properties": {
        "name": {
          "type": "string",
          "description": "Publication name"
        },
        "url": {
          "type": "string",
          "format": "uri",
          "description": "Article URL"
        }
      },
      "required": ["name", "url"]
    },
    "scoring": {
      "type": "object",
      "properties": {
        "impact": {
          "type": "number",
          "minimum": 0,
          "maximum": 10,
          "description": "Impact score 0-10"
        },
        "relevance": {
          "type": "number",
          "minimum": 0,
          "maximum": 10,
          "description": "Relevance score 0-10"
        },
        "specificity": {
          "type": "number",
          "minimum": 0,
          "maximum": 10,
          "description": "Specificity score 0-10"
        },
        "total": {
          "type": "number",
          "minimum": 0,
          "maximum": 30,
          "description": "Total score (sum of above)"
        },
        "selectionReason": {
          "type": "string",
          "minLength": 30,
          "maxLength": 300,
          "description": "Why this article was selected"
        }
      },
      "required": ["impact", "relevance", "specificity", "total", "selectionReason"]
    }
  },
  "required": ["id", "title", "summary", "body", "source", "scoring"]
}
