{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://pipelinepilot.local/news_story.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["id", "title", "summary", "body", "source", "scoring"],
  "properties": {
    "id": { "type": "string", "minLength": 1, "maxLength": 120 },
    "title": { "type": "string", "minLength": 4, "maxLength": 240 },
    "summary": { "type": "string", "minLength": 40, "maxLength": 300 },
    "body": { "type": "string", "minLength": 400, "maxLength": 4000 },
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "url"],
      "properties": {
        "name": { "type": "string", "minLength": 2, "maxLength": 120 },
        "url": { "type": "string", "format": "uri" }
      }
    },
    "scoring": {
      "type": "object",
      "additionalProperties": false,
      "required": ["impact", "relevance", "specificity", "total", "selectionReason"],
      "properties": {
        "impact": { "type": "integer", "minimum": 0, "maximum": 10 },
        "relevance": { "type": "integer", "minimum": 0, "maximum": 10 },
        "specificity": { "type": "integer", "minimum": 0, "maximum": 10 },
        "total": { "type": "integer", "minimum": 0, "maximum": 30 },
        "selectionReason": { "type": "string", "minLength": 30, "maxLength": 300 }
      }
    }
  }
}
