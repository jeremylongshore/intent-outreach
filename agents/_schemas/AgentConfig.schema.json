{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://pipelinepilot.local/AgentConfig.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["$schema", "id", "name", "role", "model", "description", "instructions", "output_schema", "tools", "routing"],
  "properties": {
    "$schema": { "const": "./_schemas/AgentConfig.schema.json" },
    "id": { "type": "string", "pattern": "^agent\\.(orchestrator|research|enrich|outreach)$" },
    "name": { "type": "string" },
    "role": { "type": "string", "enum": ["orchestrator","research","enrich","outreach"] },
    "model": { "type": "string", "minLength": 1 },
    "description": { "type": "string", "minLength": 4 },
    "instructions": { "type": "string", "minLength": 20, "maxLength": 4000 },
    "examples": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["user", "assistant"],
        "properties": {
          "user": { "type": "string", "minLength": 1, "maxLength": 2000 },
          "assistant": { "type": "string", "minLength": 1, "maxLength": 4000 }
        }
      }
    },
    "output_schema": { "$ref": "https://json-schema.org/draft/2020-12/schema" },
    "tools": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id","type","ref","input_schema","output_schema"],
        "properties": {
          "id": { "type": "string", "minLength": 2 },
          "type": { "const": "FunctionTool" },
          "ref": { "type": "string", "pattern": "^(connectors|newsfeed-demo)/.+\\.(ts)#.+$" },
          "input_schema": { "type": "object" },
          "output_schema": { "type": "object" }
        }
      }
    },
    "routing": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type","steps"],
      "properties": {
        "type": { "type": "string", "enum": ["sequential"] },
        "steps": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["call_agent"],
            "properties": { "call_agent": { "type": "string" } }
          }
        },
        "parallel": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["call_function"],
            "properties": { "call_function": { "type": "string", "pattern": "^newsfeed-demo/.+\\.ts#.+$" } }
          }
        }
      }
    },
    "policies": { "type": "object" }
  }
}
