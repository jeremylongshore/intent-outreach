{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://pipelinepilot.io/schemas/AgentConfig.schema.json",
  "title": "ADK Agent Configuration",
  "description": "Validates agent YAML files for PipelinePilot",
  "type": "object",
  "required": ["$schema", "id", "name", "role", "model"],
  "additionalProperties": false,
  "properties": {
    "$schema": {
      "type": "string",
      "format": "uri",
      "description": "JSON Schema URI for validation"
    },
    "id": {
      "type": "string",
      "pattern": "^agent_[0-9]+_[a-z_]+$",
      "description": "Unique agent identifier (e.g., agent_0_orchestrator)"
    },
    "name": {
      "type": "string",
      "minLength": 3,
      "maxLength": 100,
      "description": "Human-readable agent name"
    },
    "role": {
      "type": "string",
      "minLength": 10,
      "maxLength": 500,
      "description": "Agent's purpose and responsibilities"
    },
    "model": {
      "type": "string",
      "enum": ["gemini-2.5-flash", "gemini-1.5-pro", "gemini-1.5-flash"],
      "description": "Vertex AI model to use"
    },
    "tools": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["type", "path"],
        "properties": {
          "type": {
            "type": "string",
            "enum": ["function_tool"]
          },
          "path": {
            "type": "string",
            "pattern": "^connectors/.+\\.tool\\.(ts|js)$"
          }
        }
      },
      "description": "List of FunctionTools this agent can use"
    },
    "routing": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["agent", "mode"],
        "properties": {
          "agent": {
            "type": "string",
            "pattern": "^agent_[0-9]+_[a-z_]+$"
          },
          "mode": {
            "type": "string",
            "enum": ["sequential", "parallel"]
          },
          "condition": {
            "type": "string"
          }
        }
      },
      "description": "Routing to other agents (orchestrator only)"
    },
    "output_schema": {
      "type": "object",
      "description": "JSON Schema for agent output"
    }
  }
}
