{
  "name": "intent-outreach",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Intent Outreach — a model-agnostic, Claude-Code-native SDR orchestrator (research → enrich → outreach). Local-only, BYO keys, zero Google dependency.",
  "license": "SEE LICENSE IN LICENSE",
  "author": "Jeremy Longshore <jeremy@intentsolutions.io> (https://intentsolutions.io)",
  "homepage": "https://github.com/jeremylongshore/intent-outreach",
  "bin": {
    "intent-outreach": "bundle/cli.mjs"
  },
  "files": [
    "bundle/",
    "prompts/",
    "pipeline_core/",
    "mcp/",
    "skills/",
    "agents/",
    "hooks/",
    "profiles/",
    ".mcp.json",
    ".claude-plugin/"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json && node -e \"require('fs').cpSync('prompts','dist/prompts',{recursive:true})\"",
    "bundle": "esbuild mcp/server.ts --bundle --platform=node --format=esm --outfile=bundle/server.mjs && esbuild cli.ts --bundle --platform=node --format=esm --banner:js='#!/usr/bin/env node' --outfile=bundle/cli.mjs",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "mcp": "tsx mcp/server.ts",
    "evals": "npx -y promptfoo eval -c evals/promptfooconfig.yaml",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^1.0.0",
    "@modelcontextprotocol/sdk": "^1.0.0",
    "ai": "^4.0.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "esbuild": "^0.28.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  },
  "optionalDependencies": {
    "@ai-sdk/google": "^1.0.0",
    "@ai-sdk/openai": "^1.0.0",
    "@ai-sdk/xai": "^1.0.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
