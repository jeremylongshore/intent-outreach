{
  "name": "pipelinepilot",
  "version": "0.2.0",
  "private": true,
  "type": "module",
  "description": "Vertex-native SDR orchestration platform for agencies (leaseable SaaS)",
  "scripts": {
    "dev": "tsx src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "adk:deploy": "adk deploy agent_engine --project=${GCP_PROJECT_ID} --region=${GCP_REGION} --staging_bucket=${VERTEX_STORAGE_BUCKET} agents/orchestrator.yaml",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src providers tools agents schemas --ext .ts,.js"
  },
  "dependencies": {
    "@google-cloud/firestore": "^7.10.0",
    "@google-cloud/storage": "^7.13.0",
    "@google-cloud/secret-manager": "^5.6.0",
    "axios": "^1.7.7",
    "express": "^4.21.1",
    "zod": "^3.23.8",
    "yaml": "^2.5.1",
    "stripe": "^16.0.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.9.0",
    "tsx": "^4.19.1",
    "typescript": "^5.6.3",
    "eslint": "^9.14.0"
  }
}
