{
  "name": "pipelinepilot",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "ADK-based SDR orchestration with Vertex AI Agent Engine + Firestore",
  "scripts": {
    "arv": "node scripts/validate_arv.mjs",
    "typecheck": "tsc --noEmit",
    "build": "tsc",
    "enable:firestore": "bash scripts/enable_firestore.sh",
    "deploy:agents": "bash scripts/deploy_agents.sh",
    "demo": "tsx newsfeed-demo/demo_runner.ts"
  },
  "dependencies": {
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1",
    "yaml": "^2.6.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
