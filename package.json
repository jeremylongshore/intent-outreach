{
  "name": "intent-outreach",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Intent Outreach — a model-agnostic, Claude-Code-native SDR orchestrator (research → enrich → outreach). Local-only, BYO keys, zero Google dependency.",
  "license": "SEE LICENSE IN LICENSE",
  "author": "Jeremy Longshore <jeremy@intentsolutions.io> (https://intentsolutions.io)",
