# Intent Outreach — BYO keys. Set only what you use; everything is read LOCALLY
# (from your env or a local secrets file) and sent only to each provider's own API.
# Nothing here is required to exist as a file — env vars work directly. Copy to
# .env for local dev if you like (it is gitignored).

# ── Model provider (Claude is the default; others are gated until they pass evals) ──
ANTHROPIC_API_KEY=
# Optional alternates (only run once promoted past the eval gate, or with the override below):
OPENAI_API_KEY=
GEMINI_API_KEY=
XAI_API_KEY=
# Optional: drive a non-Anthropic model from inside Claude Code via an LLM gateway (LiteLLM/Bifrost)
ANTHROPIC_BASE_URL=
# Optional: override the model id, or bypass the provider eval gate for local testing
INTENT_OUTREACH_MODEL=
INTENT_OUTREACH_ALLOW_UNGATED=

# ── Data connectors (each self-skips if its key is unset) ──
# Free tiers — a full campaign can run for $0 with just these two:
APOLLO_API_KEY=
HUNTER_API_KEY=
# More free-tier connectors:
PDL_API_KEY=
EXA_API_KEY=
# Paid connectors:
CRUNCHBASE_API_KEY=
LEADMAGIC_API_KEY=
# Clay is push-only middleware — needs BOTH:
CLAY_API_KEY=
CLAY_WEBHOOK_URL=
# Legacy (works only with a pre-2024 Clearbit key):
CLEARBIT_API_KEY=
# Enterprise (a pre-obtained ZoomInfo JWT bearer):
ZOOMINFO_JWT=

# ── Local store overrides (optional) ──
# Where run records + a local secrets file live (default: ~/.intent-outreach)
INTENT_OUTREACH_HOME=
# Path to a JSON secrets file, if you prefer that over env vars
INTENT_OUTREACH_SECRETS_FILE=
# Override the prompts directory (evals use this)
INTENT_OUTREACH_PROMPTS_DIR=
