# GCP Configuration
GCP_PROJECT_ID=your-project
GCP_REGION=us-central1
VERTEX_STORAGE_BUCKET=vertex-ai-staging-your-project
FIRESTORE_LOCATION=us-central

# Billing (Stripe)
STRIPE_SECRET_KEY=sk_live_***
STRIPE_PRICE_FLAT_MONTHLY=price_***
STRIPE_WEBHOOK_SECRET=whsec_***

# Pricing & Commission (overrides allowed per-tenant)
DEFAULT_FLAT_MONTHLY_USD=499
DEFAULT_SEAT_USD=49
DEFAULT_COMMISSION_RATE_BPS=500   # 5% = 500 basis points
DEFAULT_COMMISSION_MODEL=meetings # "meetings"|"sourced_mrr"

# Provider API Keys (tenant may bring their own via GSM references)
CLAY_API_KEY=***
APOLLO_API_KEY=***
CLEARBIT_API_KEY=***
HUBSPOT_PRIVATE_APP_TOKEN=***
HUNTER_API_KEY=***

# Service Configuration
PORT=8080
NODE_ENV=production
LOG_LEVEL=info
