{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://pipelinepilot.io/schemas/lease_contract.schema.json",
  "title": "LeaseContract",
  "description": "Lease contract schema for PipelinePilot tenant agreements",
  "type": "object",
  "properties": {
    "tenantId": {
      "type": "string",
      "pattern": "^t_[0-9]{10,}_[a-z0-9]{9}$",
      "description": "Unique tenant identifier"
    },
    "name": {
      "type": "string",
      "minLength": 1,
      "maxLength": 100,
      "description": "Tenant organization name"
    },
    "email": {
      "type": "string",
      "format": "email",
      "description": "Primary contact email"
    },
    "plan": {
      "type": "string",
      "enum": ["starter", "growth", "scale"],
      "description": "Pricing tier"
    },
    "flatMonthlyUSD": {
      "type": "number",
      "minimum": 0,
      "description": "Monthly flat fee in USD"
    },
    "seatUSD": {
      "type": "number",
      "minimum": 0,
      "description": "Per-seat monthly fee in USD"
    },
    "commissionModel": {
      "type": "string",
      "enum": ["meetings", "sourced_mrr"],
      "description": "Commission calculation model"
    },
    "commissionRateBps": {
      "type": "integer",
      "minimum": 0,
      "maximum": 10000,
      "description": "Commission rate in basis points (100 bps = 1%)"
    },
    "effectiveFrom": {
      "type": "string",
      "format": "date",
      "description": "Contract effective date (YYYY-MM-DD)"
    },
    "status": {
      "type": "string",
      "enum": ["active", "suspended", "cancelled"],
      "description": "Current contract status"
    },
    "createdAt": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp of creation"
    },
    "updatedAt": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp of last update"
    },
    "notes": {
      "type": "string",
      "maxLength": 500,
      "description": "Additional notes about the contract"
    },
    "stripeCustomerId": {
      "type": "string",
      "pattern": "^cus_",
      "description": "Stripe customer ID"
    }
  },
  "required": [
    "tenantId",
    "name",
    "email",
    "plan",
    "flatMonthlyUSD",
    "seatUSD",
    "commissionModel",
    "commissionRateBps",
    "effectiveFrom",
    "status",
    "createdAt"
  ],
  "additionalProperties": false
}
