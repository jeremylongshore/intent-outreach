{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://pipelinepilot.io/schemas/billing_invoice.schema.json",
  "title": "BillingInvoice",
  "description": "Billing invoice schema for PipelinePilot monthly charges",
  "type": "object",
  "properties": {
    "tenantId": {
      "type": "string",
      "pattern": "^t_",
      "description": "Tenant identifier"
    },
    "period": {
      "type": "string",
      "pattern": "^[0-9]{4}-[0-9]{2}$",
      "description": "Billing period (YYYY-MM format)"
    },
    "lineItems": {
      "type": "array",
      "description": "Invoice line items",
      "items": {
        "type": "object",
        "properties": {
          "type": {
            "type": "string",
            "enum": ["flat", "seat", "commission"],
            "description": "Line item type"
          },
          "description": {
            "type": "string",
            "description": "Human-readable line item description"
          },
          "amountUSD": {
            "type": "number",
            "minimum": 0,
            "description": "Line item amount in USD"
          },
          "quantity": {
            "type": "number",
            "minimum": 0,
            "description": "Quantity (for seat charges)"
          },
          "rate": {
            "type": "number",
            "minimum": 0,
            "description": "Unit rate (for seat charges)"
          }
        },
        "required": ["type", "amountUSD"]
      },
      "minItems": 1
    },
    "totalUSD": {
      "type": "number",
      "minimum": 0,
      "description": "Total invoice amount in USD"
    },
    "stripeInvoiceId": {
      "type": ["string", "null"],
      "pattern": "^in_",
      "description": "Stripe invoice ID (if created)"
    },
    "status": {
      "type": "string",
      "enum": ["draft", "finalized", "paid", "payment_failed", "void"],
      "description": "Invoice status"
    },
    "createdAt": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp of creation"
    },
    "paidAt": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp of payment"
    },
    "failedAt": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp of payment failure"
    }
  },
  "required": ["tenantId", "period", "lineItems", "totalUSD", "status", "createdAt"],
  "additionalProperties": false
}
