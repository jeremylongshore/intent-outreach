rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function authed() { return request.auth != null; }

    match /campaigns/{id} {
      allow read, write: if authed();
      match /leads/{leadId} { allow read, write: if authed(); }
      match /enriched_leads/{leadId} { allow read, write: if authed(); }
      match /messages/{msgId} { allow read, write: if authed(); }
    }

    match /queues/{id} { allow read, write: if authed(); }
    match /usage/{id}  { allow read, write: if authed(); }
  }
}
