{
  "hosting": {
    "public": "dashboard/out",
    "ignore": ["firebase.json", "**/.*", "**/node_modules/**"],
    "rewrites": [
      {"source": "/api/**", "function": "api"}
    ]
  },
  "functions": {
    "source": "functions",
    "ignored": ["**/node_modules/**", "**/.git/**"],
    "runtime": "nodejs20"
  }
}
